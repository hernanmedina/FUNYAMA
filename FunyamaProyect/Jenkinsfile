pipeline {
    agent any
    
    environment {
        // Variables para docker-compose
        APP_PORT = '8081'
        DB_PASSWORD = 'secret'
        DB_DATABASE = 'laravel'
        DB_USERNAME = 'sail'
        WWWUSER = '1000'
        WWWGROUP = '1000'
        
        // Cache directories
        COMPOSER_CACHE_DIR = '/tmp/composer-cache'
        NPM_CACHE_DIR = '/tmp/npm-cache'
    }
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', 
                    url: 'https://github.com/hernanmedina/FUNYAMA.git'
            }
        }

        stage('Debug - List files') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "===== DIRECTORIO ACTUAL ====="
                            pwd
                            
                            echo "===== ARCHIVOS EN FunyamaProyect ====="
                            ls -la
                            
                            echo "===== VERIFICANDO composer.json ====="
                            if [ -f "composer.json" ]; then
                                echo "✓ composer.json EXISTE"
                            else
                                echo "✗ composer.json NO EXISTE"
                                exit 1
                            fi
                            
                            echo "===== VERIFICANDO package.json ====="
                            if [ -f "package.json" ]; then
                                echo "✓ package.json EXISTE"
                            else
                                echo "✗ package.json NO EXISTE"
                                exit 1
                            fi
                            
                            echo "===== VERIFICANDO Dockerfile ====="
                            if [ -f "Dockerfile" ]; then
                                echo "✓ Dockerfile EXISTE"
                                echo "Contenido de Dockerfile (primeras líneas):"
                                head -20 Dockerfile
                            else
                                echo "✗ Dockerfile NO EXISTE"
                                exit 1
                            fi
                        '''
                    }
                }
            }
        }
        
        stage('Build Docker Images') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "🔨 Construyendo imágenes Docker..."
                            docker compose build --no-cache
                            echo "✅ Imágenes construidas correctamente"
                        '''
                    }
                }
            }
        }
        
        stage('Start Containers') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            # Limpiar contenedores antiguos
                            echo "🧹 Limpiando contenedores antiguos..."
                            docker compose down --remove-orphans 2>/dev/null || true
                            
                            # Iniciar contenedores nuevos
                            echo "🚀 Iniciando nuevos contenedores..."
                            docker compose up -d
                            
                            # Esperar a que MySQL esté listo
                            echo "⏳ Esperando 15 segundos para que MySQL se inicialice..."
                            sleep 15
                            
                            # Verificar que los contenedores estén corriendo
                            echo "📋 Estado de los contenedores:"
                            docker compose ps
                            
                            # Verificar Node.js en el contenedor
                            echo "🔍 Verificando Node.js en el contenedor..."
                            if docker compose exec -T app node --version; then
                                echo "✅ Node.js instalado correctamente"
                            else
                                echo "❌ Node.js no está instalado en el contenedor"
                                echo "Verifica que el Dockerfile incluya Node.js"
                                exit 1
                            fi
                        '''
                    }
                }
            }
        }
        
        stage('Install Dependencies (Parallel)') {
            parallel {
                stage('Install PHP Dependencies') {
                    steps {
                        script {
                            dir('FunyamaProyect') {
                                sh '''
                                    echo "📦 Instalando dependencias PHP..."
                                    docker compose exec -T app composer install \
                                        --no-interaction \
                                        --prefer-dist \
                                        --optimize-autoloader \
                                        --no-progress
                                    echo "✅ Dependencias PHP instaladas"
                                '''
                            }
                        }
                    }
                }
                
                stage('Install Frontend Dependencies') {
                    steps {
                        script {
                            dir('FunyamaProyect') {
                                sh '''
                                    echo "📦 Instalando dependencias Node..."
                                    docker compose exec -T app npm ci \
                                        --no-audit \
                                        --no-fund \
                                        --cache ${NPM_CACHE_DIR} \
                                        --prefer-offline
                                    echo "✅ Dependencias Node instaladas"
                                '''
                            }
                        }
                    }
                }
            }
        }
        
        stage('Build Frontend Assets') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "🔨 Compilando assets con Vite..."
                            
                            # Intentar producción primero
                            if docker compose exec -T app npm run build; then
                                echo "✅ Build de producción exitoso"
                            else
                                echo "⚠️  Build de producción falló, intentando build de desarrollo..."
                                docker compose exec -T app npm run dev
                            fi
                            
                            # Verificar que el manifest existe
                            echo "🔍 Verificando manifest.json..."
                            if docker compose exec -T app test -f public/build/manifest.json; then
                                echo "✅ manifest.json encontrado"
                                echo "📄 Contenido:"
                                docker compose exec -T app cat public/build/manifest.json | head -n 10
                            else
                                echo "❌ Error: manifest.json no encontrado después del build"
                                exit 1
                            fi
                        '''
                    }
                }
            }
        }
        
        stage('Setup Environment') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "⚙️ Configurando entorno..."
                            
                            # Crear .env desde .env.example si no existe
                            if ! docker compose exec -T app test -f .env; then
                                docker compose exec -T app cp .env.example .env
                            fi
                            
                            # Configurar base de datos
                            docker compose exec -T app sed -i "s/DB_CONNECTION=.*/DB_CONNECTION=mysql/" .env
                            docker compose exec -T app sed -i "s/DB_HOST=.*/DB_HOST=mysql/" .env
                            docker compose exec -T app sed -i "s/DB_DATABASE=.*/DB_DATABASE=${DB_DATABASE}/" .env
                            docker compose exec -T app sed -i "s/DB_USERNAME=.*/DB_USERNAME=${DB_USERNAME}/" .env
                            docker compose exec -T app sed -i "s/DB_PASSWORD=.*/DB_PASSWORD=${DB_PASSWORD}/" .env
                            
                            # Configurar variables para testing
                            docker compose exec -T app sed -i "s/APP_ENV=.*/APP_ENV=testing/" .env
                            docker compose exec -T app sed -i "s/APP_DEBUG=.*/APP_DEBUG=true/" .env
                            
                            # Generar key
                            docker compose exec -T app php artisan key:generate
                            
                            # Limpiar y cachear configuración
                            docker compose exec -T app php artisan config:clear
                            docker compose exec -T app php artisan config:cache
                            
                            echo "✅ Entorno configurado"
                        '''
                    }
                }
            }
        }
        
        stage('Run Migrations') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "🔄 Ejecutando migraciones..."
                            docker compose exec -T app php artisan migrate:fresh --force
                            echo "✅ Migraciones ejecutadas"
                        '''
                    }
                }
            }
        }
        
        stage('Run Tests (Parallel)') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        script {
                            dir('FunyamaProyect') {
                                sh '''
                                    echo "🧪 Ejecutando tests unitarios..."
                                    docker compose exec -T app php artisan test \
                                        --testsuite=Unit \
                                        --verbose \
                                        --stop-on-failure || true
                                '''
                            }
                        }
                    }
                }
                
                stage('Feature Tests') {
                    steps {
                        script {
                            dir('FunyamaProyect') {
                                sh '''
                                    echo "🧪 Ejecutando tests de funcionalidad..."
                                    docker compose exec -T app php artisan test \
                                        --testsuite=Feature \
                                        --verbose \
                                        --stop-on-failure || true
                                '''
                            }
                        }
                    }
                }
            }
        }
        
        stage('Generate Test Reports') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "📊 Generando reporte de tests..."
                            docker compose exec -T app php artisan test \
                                --log-junit test-results.xml || true
                        '''
                    }
                }
            }
            post {
                always {
                    script {
                        dir('FunyamaProyect') {
                            // Publicar reportes JUnit
                            junit allowEmptyResults: true, testResults: 'test-results.xml'
                        }
                    }
                }
            }
        }
        
        stage('Deploy') {
            steps {
                echo '🚀 Deploy step - add your deployment commands here'
                // Aquí puedes añadir tus comandos de despliegue
                // Ejemplo: docker push, kubectl apply, etc.
            }
        }
        
        stage('Cleanup') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "🧹 Limpiando contenedores..."
                            docker compose down
                            echo "✅ Limpieza completada"
                        '''
                    }
                }
            }
        }
    }
    
    post {
        always {
            echo "🏁 Pipeline finalizado"
            cleanWs()
        }
        failure {
            echo "❌ Pipeline falló"
            // Aquí puedes añadir notificaciones de error
            // Ejemplo: slackSend, email, etc.
        }
        success {
            echo "✅ Pipeline ejecutado exitosamente"
            // Aquí puedes añadir notificaciones de éxito
        }
        unstable {
            echo "⚠️ Pipeline inestable - algunos tests fallaron"
        }
    }
}