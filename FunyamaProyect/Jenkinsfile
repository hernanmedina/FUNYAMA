pipeline {
    agent any
    
    environment {
        DB_PASSWORD = 'secret'
    }
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', 
                    url: 'https://github.com/hernanmedina/FUNYAMA.git'
            }
        }

        stage('Debug - List files in FunyamaProyect') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "===== DIRECTORIO ACTUAL ====="
                            pwd
                            
                            echo "===== LISTADO COMPLETO DE ARCHIVOS ====="
                            ls -la
                            
                            echo "===== BUSCANDO composer.json ====="
                            if [ -f "composer.json" ]; then
                                echo "✓ composer.json EXISTE"
                                echo "Primeras líneas:"
                                head -5 composer.json
                            else
                                echo "✗ composer.json NO EXISTE"
                                echo "Buscando en subdirectorios:"
                                find . -name "composer.json" -type f || echo "No se encontró"
                            fi
                            
                            echo "===== BUSCANDO ARTISAN ====="
                            if [ -f "artisan" ]; then
                                echo "✓ artisan EXISTE"
                            else
                                echo "✗ artisan NO EXISTE"
                            fi
                            
                            echo "===== VERIFICANDO .dockerignore ====="
                            if [ -f ".dockerignore" ]; then
                                echo "Contenido de .dockerignore:"
                                cat .dockerignore
                            else
                                echo "No hay .dockerignore"
                            fi
                        '''
                    }
                }
            }
        }

        stage('Debug - Check files before build') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            echo "===== DIRECTORIO ACTUAL ====="
                            pwd
                            
                            echo "===== ARCHIVOS EN FunyamaProyect ====="
                            ls -la
                            
                            echo "===== BUSCANDO composer.json ESPECÍFICAMENTE ====="
                            if [ -f "composer.json" ]; then
                                echo "✓ composer.json EXISTE"
                                echo "Contenido:"
                                head -20 composer.json
                            else
                                echo "✗ composer.json NO EXISTE"
                                echo "Buscando en subdirectorios..."
                                find . -name "composer.json" -type f
                            fi
                            
                            echo "===== VERIFICANDO .dockerignore ====="
                            if [ -f ".dockerignore" ]; then
                                echo "Contenido de .dockerignore:"
                                cat .dockerignore
                            else
                                echo "No hay .dockerignore"
                            fi
                        '''
                    }
                }
            }
        }
        
        stage('Cleanup and Start Containers') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            # Limpiar contenedores antiguos
                            echo "Limpiando contenedores antiguos..."
                            docker compose down --remove-orphans 2>/dev/null || true
                            
                            # Iniciar contenedores nuevos
                            echo "Iniciando nuevos contenedores..."
                            export DB_PASSWORD=${DB_PASSWORD:-secret}
                            docker compose up -d
                            
                            # Esperar a que estén listos
                            echo "Esperando 10 segundos para que los contenedores se inicialicen..."
                            sleep 10
                            
                            # Verificar que los contenedores estén corriendo
                            docker compose ps
                        '''
                    }
                }
            }
        }
        
        stage('Build Docker Images') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            export DB_PASSWORD=${DB_PASSWORD:-secret}
                            docker compose build --no-cache
                        '''
                    }
                }
            }
        }
        
        stage('Install Dependencies') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            docker compose exec -T app composer install --no-interaction --prefer-dist
                        '''
                    }
                }
            }
        }
        
        stage('Run Migrations') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            export DB_PASSWORD=password
                            docker compose exec -T app cp .env.example .env

                            docker compose exec -T app sed -i "s/DB_CONNECTION=.*/DB_CONNECTION=mysql/" .env
                            docker compose exec -T app sed -i "s/DB_HOST=.*/DB_HOST=mysql/" .env
                            docker compose exec -T app sed -i "s/DB_DATABASE=.*/DB_DATABASE=laravel/" .env
                            docker compose exec -T app sed -i "s/DB_USERNAME=.*/DB_USERNAME=sail/" .env
                            docker compose exec -T app sed -i "s/DB_PASSWORD=.*/DB_PASSWORD=secret/" .env

                            docker compose exec -T app php artisan key:generate
                            docker compose exec -T app php artisan migrate:fresh --force
                        '''
                    }
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            docker compose exec -T app php artisan test
                        '''
                    }
                }
            }
        }
        
        stage('Build Frontend') {
            steps {
                script {
                    dir('FunyamaProyect') {
                        sh '''
                            docker compose exec -T app npm install
                            docker compose exec -T app npm run build
                        '''
                    }
                }
            }
        }
        
        stage('Deploy') {
            steps {
                echo 'Deploy step - add your deployment commands here'
            }
        }
    }
}
